# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=SecureFrame Gallery
APP_VERSION=1.0.0
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────
# SQLite (desarrollo local)
DATABASE_URL=sqlite:///./secureframe.db

# PostgreSQL (producción - descomentar y configurar)
# DATABASE_URL=postgresql://user:password@localhost:5432/secureframe_db

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32_output
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute

# ── CORS ─────────────────────────────────────────────────────────────────
# En producción reemplazar * por la URL del frontend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
