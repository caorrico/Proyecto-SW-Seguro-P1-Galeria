APP_NAME=SecureFrame Gallery
APP_VERSION=1.0.0
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────
# Opción 1: PostgreSQL via Docker (recomendado para desarrollo)
DATABASE_URL=postgresql://secureframe:secureframe_dev_2026@localhost:5432/secureframe_db

# Opción 2: SQLite local (sin Docker, solo para pruebas rápidas)
# DATABASE_URL=sqlite:///./secureframe.db

# Opción 3: PostgreSQL en producción (Railway/Render)
# DATABASE_URL=postgresql://user:password@host:5432/db_name

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32_output
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
